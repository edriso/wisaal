generator client {
  provider = "prisma-client"
  output   = "../src/database/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Naming: TS model names are PascalCase singular and TS fields are
// camelCase (idiomatic TypeScript). The @map / @@map directives expose
// snake_case plural tables and snake_case columns in MySQL (the usual SQL
// convention). We do NOT use Prisma enums; short string fields with a
// comment listing the allowed values keep migrations simpler, matching the
// other bots in this folder (ayah, tilawah).

// ─── Users ──────────────────────────────────────────────────────────
//
// One row per person the bot nudges. Each user keeps their own circle of
// relatives (Person rows) and is reminded, on their chosen cadence, to reach
// out to ONE of them at a time, rotating fairly. All scheduling is driven by
// the user's own timezone and quiet-hours window.

model User {
  id         Int    @id @default(autoincrement())
  telegramId BigInt @unique @map("telegram_id")
  // UI language. v1 ships Arabic only.
  language   String @default("ar") @db.VarChar(8) // allowed: ar, en — v1 ar only
  // IANA timezone, e.g. "Africa/Cairo". Drives the local clock used for the
  // quiet-hours window and the per-cycle idempotency date key.
  timezone   String @default("Africa/Cairo") @db.VarChar(64)

  // The reminder cadence (whole days) applied to a NEWLY added relative. Each
  // relative then carries their own Person.cadenceDays, tunable per person from
  // /list; this is just the starting value for new additions. 7 = weekly.
  defaultCadenceDays Int @default(7) @map("default_cadence_days")

  // The quiet window, in the user's LOCAL hour (0-23). No nudge is sent while
  // the local clock is inside it. The window may wrap past midnight: with
  // start 22 and end 8 the quiet time runs 22:00 → 08:00. See
  // src/core/eligibility.ts (isQuietHour) for the wrap-around handling.
  quietStartHour Int @default(22) @map("quiet_start_hour") @db.TinyInt
  quietEndHour   Int @default(8) @map("quiet_end_hour") @db.TinyInt

  // Snooze: when set and still in the future, suppress nudges until then.
  // Cleared (or simply passed) once the moment is reached.
  snoozeUntil DateTime? @map("snooze_until")
  // Break: when true the bot sends nothing. Unlike snooze this is indefinite,
  // cleared only when the user resumes.
  paused      Boolean   @default(false)
  // Reachability: set when Telegram tells us the user blocked the bot (or a
  // send fails with 403). Nudge loops filter `blocked = false`.
  blocked     Boolean   @default(false)

  // When the last nudge was actually sent. Kept for diagnostics and so a /now
  // pull can record the day's nudge; eligibility itself is now decided per
  // relative (see Person.cadenceDays). Null means never nudged yet.
  lastNudgeAt DateTime? @map("last_nudge_at")

  createdAt DateTime @default(now()) @map("created_at")

  people    Person[]
  nudgeLogs NudgeLog[]

  @@map("users")
}

// ─── People (the user's circle of relatives) ────────────────────────

model Person {
  id     Int    @id @default(autoincrement())
  userId Int    @map("user_id")
  name   String @db.VarChar(128)
  // Free-text relationship label, e.g. "خالتي". Optional.
  relation String? @db.VarChar(64)
  // How many whole days to wait, since this relative was last contacted, before
  // they are due again. 1 = daily, 7 = weekly, 30 ≈ monthly. The cadence is
  // per relative, so the user can keep in closer touch with some than others.
  // The default is a gentle weekly. See src/core/eligibility.ts (isPersonDue).
  cadenceDays Int @default(7) @map("cadence_days")
  // When the user last marked this person as contacted. Drives both the fair
  // rotation (src/core/rotation.ts) and the per-relative due check: a
  // never-contacted person (null) is always due and picked first; among
  // contacted, the least-recently is next, and each is due again cadenceDays
  // after their lastContactedAt.
  lastContactedAt DateTime? @map("last_contacted_at")

  createdAt DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nudgeLogs NudgeLog[]

  @@index([userId])
  @@map("people")
}

// ─── Nudge history + idempotency ────────────────────────────────────

model NudgeLog {
  id       Int  @id @default(autoincrement())
  userId   Int  @map("user_id")
  // The person this nudge was about. Nullable so a log row survives even if
  // the person is later removed (we keep the history; the FK sets it null).
  personId Int? @map("person_id")
  // What happened: the bot nudged, or the user acted on it.
  action   String @db.VarChar(16) // allowed: nudged, contacted, snoozed, skipped
  // The user's LOCAL date the nudge was meant for ("YYYY-MM-DD"). The unique
  // index below turns this into the one-nudge-per-cycle lock: a user gets at
  // most one nudge per local date, even if the cron double-fires or catches
  // up after a restart. Mirrors ayah's DeliveryLog.scheduledFor lock.
  scheduledFor DateTime @map("scheduled_for")

  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([userId, scheduledFor], map: "nudge_logs_user_date_key")
  @@index([userId])
  @@map("nudge_logs")
}
